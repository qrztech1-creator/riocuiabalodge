// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// NOTE: For local development we use SQLite.
// When deploying to Vercel, change provider to "postgresql" 
// and set POSTGRES_URL in the Vercel dashboard.
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String   @id @default(uuid())
  title       String
  slug        String   @unique
  category    String   // "EVENTO" or "ARTIGO"
  content     String
  coverImage  String
  thumbnailImage String?
  readTime    Int      @default(2)
  status      String   @default("PUBLISHED") // "DRAFT" or "PUBLISHED"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Role {
  SUPERADMIN
  EDITOR
}

model User {
  id           String   @id @default(uuid())
  name         String?
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
